# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<app>
MONGODB_URI=

# ─── Cloudinary (PDF Storage) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Any long random string, e.g. generated with: openssl rand -hex 32
JWT_SECRET=
